[0.005, "o", "\u001b[52;22H\u001b[1;52r\u001b[1;1H\u001b[12M\u001b[1;53r\u001b[41;1H\u001b[38;5;130m153 \u001b[0mwhen the check actually started. Runtime is \u001b[35m`\u001b[0mtime.Now() - check.StartedAt\u001b[35m`\u001b[0m for\u001b[31C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m154 \u001b[0min-progress checks. Simple math, but surprisingly useful information.\u001b[40C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m155 \u001b[0m\u001b[109C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m156 \u001b[0m\u001b[35m## \u001b[0m\u001b[35mThe Code\u001b[0m\u001b[98C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m157 \u001b[0m\u001b[109C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m158 \u001b[0mEverything's at\u001b[94C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m159 \u001b[0m[\u001b[4m\u001b[35mfini-net/gh-observer\u001b[24m\u001b[0m](\u001b[31mhttps://github.com/fini-net/gh-observer\u001b[0m). It's open\u001b[35C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m160 \u001b[0msource, and I'm genuinely interested in feedback and contributions. If you hit\u001b[31C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m161 \u001b[0ma weird edge case or have a feature idea, open an issue.\u001b[53C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m162 \u001b[0m\u001b[109C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m163 \u001b[0mAnd yes, before you ask —\u001b[51;31H\u001b[35m`\u001b[0mgh observer\u001b[35m`\u001b[0m was partially built using \u001b[35m"]
[0.000, "o", "`\u001b[0mgh observer\u001b[35m`\u001b[0m\u001b[30C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m164 \u001b[0mto watch its own \u001b[103mCI\u001b[0m. It's turtles all the way down.  Or the dog food tastes\u001b[34C\u001b[48;5;224m \u001b[0m\u001b[53;1H\u001b[K\u001b[53;105H164,18\u001b[8C88%\u001b[52;22H\u001b[34h\u001b[?25h"]
