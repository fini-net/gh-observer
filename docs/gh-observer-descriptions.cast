[0.003, "o", "\u001b[53;95H   \u001b[1;7H\u001b[27m\u001b[24m\u001b[23m\u001b[0m\u001b[H\u001b[J\u001b[1;1H\u001b[38;5;130m101 \u001b[0m  find out \u001b[3m*why*\u001b[23m something failed.\u001b[75C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m102 -\u001b[0m \u001b[1m**Rate limit awareness**\u001b[0m —\u001b[2;34HWhen you're getting close to GitHub API limits, it\u001b[30C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m103 \u001b[0m  automatically backs off and polls less frequently. Keeps your rate limit\u001b[35C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m104 \u001b[0m  healthy without any manual configuration.\u001b[66C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m105 -\u001b[0m \u001b[1m**CI-friendly snapshot mode**\u001b[0m —\u001b[5;39HWhen stdout isn't a TTY (like in a script or\u001b[31C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m106 \u001b[0m  pipeline), it prints a plain text snapshot and exits with an appropriate exit\u001b[30C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m107 \u001b[0m  code. So \u001b[35m`\u001b[0mgh-observer && deploy.sh\u001b[35m`\u001b[0m actually works.\u001b[56C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m108 -\u001b[0m \u001b[1m**Configurable colors**\u001b[0m —\u001b[8;33HANSI 256-color support via\u001b[55C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m109 \u001b[0m  \u001b[35m`\u001b[0m~/.config/gh-observer/config.yaml\u001b[35m`\u001b"]
[0.000, "o", "[0m if you're particular about your terminal\u001b[31C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m110 \u001b[0m  aesthetics.\u001b[96C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m111 \u001b[0m\u001b[109C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m112 \u001b[0m\u001b[35m## \u001b[0m\u001b[35mInstallation\u001b[0m\u001b[94C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m113 \u001b[0m\u001b[109C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m114 \u001b[0mThe easiest path is the precompiled binary via GitHub CLI extensions —\u001b[14;76Hno Go\u001b[33C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m115 \u001b[0mtoolchain required:\u001b[90C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m116 \u001b[0m\u001b[109C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m117 \u001b[0m\u001b[35m```bash\u001b[0m\u001b[102C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m118 \u001b[0mgh extension install fini-net/gh-observer\u001b[68C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m119 \u001b[0m\u001b[35m```\u001b[0m\u001b[106C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m120 \u001b[0m\u001b[109C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m121 \u001b[0mOr if you've got Go and want to install it that way:\u001b[57C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m122 \u001b[0m\u001b[109C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m123 \u001b[0m\u001b[35m```bash\u001b[0m\u001b[102C\u001b[48;5;224m "]
[0.002, "o", "\u001b[0m\r\n\u001b[38;5;130m124 \u001b[0mgo install github.com/fini-net/gh-observer@latest\u001b[60C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m125 \u001b[0m\u001b[35m```\u001b[0m\u001b[106C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m126 \u001b[0m\u001b[109C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m127 \u001b[0mPrecompiled binaries exist for macOS (Intel and Apple Silicon), Linux (x86-64\u001b[32C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m128 \u001b[0mand ARM64), and Windows (x86-64). All binaries include build attestations for\u001b[32C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m129 \u001b[0msupply chain security verification.\u001b[74C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m130 \u001b[0m\u001b[109C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m131 \u001b[0m\u001b[35m## \u001b[0m\u001b[35mHow to Use It\u001b[0m\u001b[93C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m132 \u001b[0m\u001b[109C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m133 \u001b[0mAuto-detect your current branch's PR:\u001b[72C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m134 \u001b[0m\u001b[109C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m135 \u001b[0m\u001b[35m```bash\u001b[0m\u001b[102C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m136 \u001b[0mgh observer\u001b[98C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m137 \u001b[0m\u001b[35m```\u001b[0m\u001b[106C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m138 \u001b[0m\u001b[109C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m139 \u001b[0mW"]
[0.000, "o", "atch a specific PR number:\u001b[82C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m140 \u001b[0m\u001b[109C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m141 \u001b[0m\u001b[35m```bash\u001b[0m\u001b[102C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m142 \u001b[0mgh observer 123\u001b[94C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m143 \u001b[0m\u001b[35m```\u001b[0m\u001b[106C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m144 \u001b[0m\u001b[109C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m145 \u001b[0m\u001b[35m## \u001b[0m\u001b[35mUnder the Hood (for the curious)\u001b[0m\u001b[74C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m146 \u001b[0m\u001b[109C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m147 \u001b[0mIt's built in Go using [\u001b[4m\u001b[35mBubbletea\u001b[24m\u001b[0m](\u001b[31mhttps://github.com/charmbracelet/bubbletea\u001b[0m)\u001b[31C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m148 \u001b[0mfor the TUI, which follows the Elm Architecture pattern —\u001b[48;63Hif you've done any\u001b[33C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m149 \u001b[0mElm or Redux, the Model/Update/View pattern will feel familiar. Lipgloss\u001b[37C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m150 \u001b[0mhandles the terminal styling.\u001b[80C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m151 \u001b[0m\u001b[109C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m152 \u001b[0mThe interesting bit technically is that it uses GitHub's Gr"]
