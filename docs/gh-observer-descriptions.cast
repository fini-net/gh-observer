[0.012, "o", "\u001b[1;1H\u001b[38;5;130m  1 \u001b[0m\u001b[35m# \u001b[0m\u001b[35mgh-observer\u001b[0m\u001b[96C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m  2 \u001b[0m\u001b[109C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m  3 \u001b[0m![\u001b[4m\u001b[35mGitHub Issues\u001b[24m\u001b[0m](\u001b[31mhttps://img.shields.io/github/issues/fini-net/gh-observer\u001b[0m)\u001b[34C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m  4 \u001b[0m![\u001b[4m\u001b[35mGitHub Pull Requests\u001b[24m\u001b[0m](\u001b[31mhttps://img.shields.io/github/issues-pr/fini-net/gh-observer\u001b[0m)\u001b[24C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m  5 \u001b[0m![\u001b[4m\u001b[35mGitHub License\u001b[24m\u001b[0m](\u001b[31mhttps://img.shields.io/github/license/fini-net/gh-observer\u001b[0m)\u001b[32C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m  6 \u001b[0m![\u001b[4m\u001b[35mGitHub watchers\u001b[24m\u001b[0m](\u001b[31mhttps://img.shields.io/github/watchers/fini-net/gh-observer\u001b[0m)\u001b[30C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m  7 \u001b[0m\u001b[109C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m  8 \u001b[0mA GitHub PR check watcher that improves on \u001b[35m`\u001b[0mgh pr checks --watch\u001b[35m`\u001b[0m by showing\u001b[33C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m  9 \u001b[0mruntime metrics, queue latency, and better handling of startup delays.\u001b[39C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m 10 \u001b[0m"]
[0.000, "o", "\u001b[109C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m 11 \u001b[0m![\u001b[4m\u001b[35mproject banner: abstract representation of code flowing through a pull request, using interconnected nodes \u001b[24m\u001b[0m\u001b[4m\u001b[35m\u001b[48;5;224ma\u001b[24m\u001b[0m\u001b[4m\u001b[35mnd liness\u001b[24m\u001b[0m\u001b[12;1H\u001b[38;5;130m    \u001b[0m\u001b[4m\u001b[35m.\u001b[24m\u001b[0m](\u001b[31mdocs/g\u001b[0m\u001b[31m\u001b[48;5;224mh\u001b[0m\u001b[31m-observer-banner.jpeg\u001b[0m)\r\n\u001b[38;5;130m 12 \u001b[0m\u001b[109C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m 13 \u001b[0m\u001b[35m## \u001b[0m\u001b[35mWhy?\u001b[0m\u001b[102C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m 14 \u001b[0m\u001b[109C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m 15 \u001b[0mThe existing \u001b[35m`\u001b[0mgh pr checks --watch\u001b[35m`\u001b[0m doesn't show how long checks have been running, doesn't handle the 30-90s\u001b[48;5;224m \u001b[0mstartup  \u001b[17;1H\u001b[38;5;130m    \u001b[0mdelay wel\u001b[48;5;224ml\u001b[0m, and doesn't show queue latency. This creates anxiety when watching CI runs - \"is it stuck or just slow?\"\r\n\u001b[38;5;130m 16 \u001b[0m\u001b[109C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m 17 \u001b[0m\u001b[35m## \u001b[0m\u001b[35mFeatures\u001b[0m\u001b[98C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m 18 "]
[0.001, "o", "\u001b[0m\u001b[109C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m 19 -\u001b[0m ⏱️\u001b[21;10H\u001b[1m**Runtime metrics**\u001b[0m - Shows elapsed time: \u001b[35m`\u001b[0m3m 52s\u001b[35m`\u001b[0m tells you exactly how long checks have been running  \u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m 20 -\u001b[0m ⏳\u001b[22;10H\u001b[1m**Queue latency**\u001b[0m - Displays wait time: \u001b[35m`\u001b[0m15s\u001b[35m`\u001b[0m shows how long GitHub queued the job before starting      \u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m 21 -\u001b[0m 🔄\u001b[23;10H\u001b[1m**Real-time updates**\u001b[0m - Auto-refreshes every 5s (configurable) without manual polling\u001b[19C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m 22 -\u001b[0m ⚡\u001b[24;10H\u001b[1m**Startup phases**\u001b[0m - Helpful messages like \"Waiting for Actions to start...\" during the 30-90s GitHub de\u001b[48;5;224ml\u001b[0may\r\n\u001b[38;5;130m 23 -\u001b[0m 🛡️\u001b[25;10H\u001b[1m**Rate limits**\u001b[0m - Backs off automatically when approaching API limits to avoid interruptions\u001b[12C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m 24 -\u001b[0m ✅\u001b[26;10H\u001b[1m**CI-friendly**\u001b[0m - Returns exit codes (0=success, 1=failure) for script automation\u001b[23C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m 25 \u001b["]
[0.000, "o", "0m\u001b[109C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m 26 \u001b[0m\u001b[35m## \u001b[0m\u001b[35mExample Output\u001b[0m\u001b[92C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m 27 \u001b[0m\u001b[109C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m 28 \u001b[0m\u001b[35m```ShellOutput\u001b[0m\u001b[95C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m 29 \u001b[0mPR #123: Add new feature\u001b[85C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m 30 \u001b[0m\u001b[109C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m 31 \u001b[0mStartup Phase (37s elapsed):\u001b[81C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m 32 \u001b[0m  ⏳\u001b[34;10HWaiting for Actions to start...\u001b[73C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m 33 \u001b[0m  💡\u001b[35;10HGitHub typically takes 30-90s to queue jobs after PR creation\u001b[43C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m 34 \u001b[0m\u001b[109C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m 35 \u001b[0mPR #5: 🔶\u001b[37;15H[claude] /init 21:04:15 UTC\u001b[72C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m 36 \u001b[0mUpdated 0s ago  •\u001b[38;24HPushed 43h 8m 11s ago\u001b[69C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m 37 \u001b[0m\u001b[109C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m 38 \u001b[0mStartup   Workflow/Job\u001b[32CDuration\u001b[47C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m 39 "]
[0.000, "o", "\u001b[0m\u001b[109C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m 40 \u001b[0m  15s ✗ MarkdownLint / lint\u001b[29C5s\u001b[51C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m 41 \u001b[0m   .github:13 - Failed with exit code: 1\u001b[69C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m 42 \u001b[0m   CLAUDE.md:100 - Lists should be surrounded by blank lines: CLAUDE.md:100 MD032/blanks-around-lists Lists s\u001b[48;5;224mh\u001b[0mould be  \u001b[45;1H\u001b[38;5;130m    \u001b[0msurr     \u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m 43 \u001b[0m\u001b[109C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m 44 \u001b[0m  15s ✓ Auto Assign / run\u001b[31C5s\u001b[51C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m 45 \u001b[0m  15s ✓ CUE Validation / verify\u001b[25C6s\u001b[51C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m 46 \u001b[0m  15s ✓ Checkov / scan\u001b[33C27s\u001b[51C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m 47 \u001b[0m  15s ✓ Claude Code Review / claude-review\u001b[10C3m 52s\u001b[51C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m 48 \u001b[0m  15s ✓ Lint GitHub Actions workflows / actionlint      8s\u001b[51C\u001b[48;5;224m \u001b[0m\r\n\u001b[38;5;130m 49 \u001b[0m  39s ✓ Checkov\u001b[41C2s\u001b[51C\u001b[48;5;224m \u001b[0m\u001b[53;105H1,1\u001b[11CTop\u001b[1;5H\u001b[34h\u001b[?25h"]
